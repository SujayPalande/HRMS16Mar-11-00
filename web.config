<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- PHP backend: No proxy rules needed. Remove Node.js proxy rules. -->
    <rewrite>
      <rules>
        <!-- Enable extensionless PHP URLs: /api/login -> /api/login.php -->
        <rule name="Remove PHP Extension" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions>
            <add input="{REQUEST_FILENAME}.php" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="{R:1}.php" />
        </rule>
      </rules>
    </rewrite>
    <!-- No proxy needed for PHP backend -->
  </system.webServer>
</configuration>
