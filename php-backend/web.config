<?xml version="1.0" encoding="UTF-8"?>
<!--
  HR Connect — IIS / SpeedCloud web.config
  ==========================================
  Serves the React SPA from the web root and routes all /api/* requests
  to the PHP backend. Requires:
    - IIS URL Rewrite module (installed on SpeedCloud by default)
    - PHP FastCGI handler registered for *.php
    - PHP 8.0+ with PDO, PDO_MySQL, mbstring, openssl, json extensions
-->
<configuration>
  <system.webServer>

    <!-- ── MIME types for SPA assets ──────────────────────────────────────── -->
    <staticContent>
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".woff"  mimeType="font/woff" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <mimeMap fileExtension=".webp"  mimeType="image/webp" />
      <mimeMap fileExtension=".svg"   mimeType="image/svg+xml" />
      <mimeMap fileExtension=".ico"   mimeType="image/x-icon" />
    </staticContent>

    <!-- ── Default documents ───────────────────────────────────────────────── -->
    <defaultDocument>
      <files>
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- ── URL Rewrite rules ──────────────────────────────────────────────── -->
    <rewrite>
      <rules>
        <!-- Rule 1: Route /api/* to the PHP backend index.php               -->
        <!-- Strips /api prefix before handing to PHP (see index.php)         -->
        <rule name="API to PHP Backend" stopProcessing="true">
          <match url="^api/(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="api/index.php" />
        </rule>

        <!-- Rule 2: Serve existing static files directly (JS, CSS, images)   -->
        <rule name="Static Assets" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Rule 3: SPA fallback — everything else → React index.html        -->
        <rule name="SPA Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <add input="{REQUEST_URI}"      pattern="^/api/"        negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- ── Security headers ───────────────────────────────────────────────── -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options"        value="SAMEORIGIN" />
        <add name="X-XSS-Protection"       value="1; mode=block" />
        <add name="Referrer-Policy"        value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <!-- ── PHP FastCGI handler ─────────────────────────────────────────────── -->
    <!-- SpeedCloud usually pre-registers this; uncomment if needed.           -->
    <!--
    <handlers>
      <add name="PHP_via_FastCGI" path="*.php" verb="*"
           modules="FastCgiModule"
           scriptProcessor="C:\Program Files\PHP\v8.2\php-cgi.exe"
           resourceType="Unspecified" requireAccess="Script" />
    </handlers>
    -->

    <!-- ── Compression ────────────────────────────────────────────────────── -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- ── Error pages (let React handle them via SPA router)  ────────────── -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>

  <!-- ── PHP environment variables via IIS application settings ────────────
       Set these in SpeedCloud Control Panel → Application Settings, OR
       add them here (less secure — prefer the control panel for secrets).     -->
  <appSettings>
    <!-- <add key="DB_HOST"        value="localhost" />          -->
    <!-- <add key="DB_NAME"        value="hrconnect" />          -->
    <!-- <add key="DB_USER"        value="hrconnect_user" />     -->
    <!-- <add key="DB_PASS"        value="YOUR_DB_PASSWORD" />   -->
    <!-- <add key="SESSION_SECRET" value="change-me-32chars+" /> -->
    <!-- <add key="APP_BASE_URL"   value="https://yourdomain.com" /> -->
    <!-- <add key="SMTP_HOST"      value="smtp.yourhost.com" />  -->
    <!-- <add key="SMTP_PORT"      value="587" />                -->
    <!-- <add key="SMTP_USER"      value="noreply@example.com" />-->
    <!-- <add key="SMTP_PASS"      value="YOUR_SMTP_PASSWORD" /> -->
    <!-- <add key="SMTP_FROM"      value="noreply@example.com" />-->
    <!-- <add key="SMTP_FROM_NAME" value="HR Connect" />         -->
  </appSettings>

</configuration>
